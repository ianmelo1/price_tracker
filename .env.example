# Database
DATABASE_URL=sqlite:///price_tracker.db

# Discord Webhook (https://support.discord.com/hc/en-us/articles/228383668)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Mercado Livre API (https://developers.mercadolivre.com.br/)
MERCADOLIVRE_APP_ID=your_app_id
MERCADOLIVRE_SECRET=your_secret

# Scheduler
CHECK_INTERVAL_MINUTES=60
